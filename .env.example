# 数据库连接（开发环境用 SQLite，生产环境推荐 PostgreSQL）
DATABASE_URL="file:./dev.db"
# 生产环境示例：
# DATABASE_URL="postgresql://user:password@host:5432/fraud-cases"

# JWT 签名密钥 — 生产环境务必使用强随机字符串
JWT_SECRET="your-jwt-secret-here"

# 上传目录（仅在本地存储模式下使用，生产环境建议接入云存储）
UPLOAD_DIR="public/uploads"

# 应用地址（用于邮件中的链接，开发环境使用默认值）
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 邮件服务（Resend，注册 https://resend.com 获取 API Key）
# RESEND_API_KEY="re_xxxxx"
# EMAIL_FROM="noreply@yourdomain.com"
